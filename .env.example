# ─── Roomeo — Environment Variables ───

# Database (PostgreSQL + PostGIS)
# Local: postgresql://postgres:postgres@localhost:5432/roomeo?schema=public
# Production (Vercel/Neon): use your Neon connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roomeo?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
BETTER_AUTH_URL="http://localhost:3000"

# Public URLs (override for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
